doctype html
html
    head
        title Login

    body
        h1 Login

        form(action="/login" method="POST")

            input(
                type="text"
                name="username"
                placeholder="Username"
                required
            )

            br
            br

            input(
                type="password"
                name="password"
                placeholder="Password"
                required
            )

            br
            br

            button(type="submit")
                | Login

        br

        a(href="/register")
            | Register