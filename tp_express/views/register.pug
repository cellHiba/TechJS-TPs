doctype html
html
    head
        title Register

    body
        h1 Register

        form(action="/register" method="POST")

            input(
                type="text"
                name="username"
                placeholder="Username"
                required
            )

            br
            br

            input(
                type="password"
                name="password"
                placeholder="Password"
                required
            )

            br
            br

            button(type="submit")
                | Register

        br

        a(href="/login")
            | Login